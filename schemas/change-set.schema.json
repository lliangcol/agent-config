{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "actions"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "scope": { "type": "string" },
          "key": { "type": "string" },
          "value": { "type": "string" },
          "policy": { "type": "string" },
          "name": { "type": "string" },
          "timeout": { "type": "integer" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
